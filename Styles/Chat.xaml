<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <ResourceDictionary.MergedDictionaries>
    <ResourceDictionary Source="../Resources/Spacing.xaml" />
    <ResourceDictionary Source="../Resources/Corners.xaml" />
    <ResourceDictionary Source="../Resources/Typography.xaml" />
    <ResourceDictionary Source="../Resources/Elevation.xaml" />
    <ResourceDictionary Source="Controls.xaml" />
  </ResourceDictionary.MergedDictionaries>

  <Style x:Key="ChatCardBorderBaseStyle" TargetType="Border">
    <Setter Property="CornerRadius" Value="{StaticResource CornerRadius.Large}" />
    <Setter Property="Padding" Value="{StaticResource Thickness.Card.Padding}" />
    <Setter Property="Background" Value="{DynamicResource Brush.Theme.SurfaceBackground}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Theme.Border}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Effect" Value="{StaticResource Effect.Shadow.Card}" />
  </Style>

  <Style x:Key="ChatBaseTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource BaseTextBoxStyle}" />

  <Style x:Key="ChatBaseButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}" />

  <Style x:Key="ChatSecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}" />

  <Style x:Key="ChatConversationSurfaceStyle" TargetType="Border" BasedOn="{StaticResource ChatCardBorderBaseStyle}">
    <Setter Property="Background" Value="{DynamicResource Brush.Theme.Chat.CanvasBackground}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Theme.Border}" />
    <Setter Property="Padding" Value="{StaticResource Thickness.Chat.CanvasPadding}" />
  </Style>

  <Style x:Key="ChatMessageBubbleBaseStyle" TargetType="Border">
    <Setter Property="Padding" Value="{StaticResource Thickness.Chat.BubblePadding}" />
    <Setter Property="CornerRadius" Value="{StaticResource CornerRadius.Bubble}" />
    <Setter Property="MaxWidth" Value="{StaticResource Size.ChatBubble.MaxWidth.Narrow}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Theme.Border}" />
  </Style>

  <Style x:Key="ChatAssistantBubbleStyle" TargetType="Border" BasedOn="{StaticResource ChatMessageBubbleBaseStyle}">
    <Setter Property="Background" Value="{DynamicResource Brush.Theme.Message.AssistantBackground}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Theme.Chat.Message.AssistantBorder}" />
    <Setter Property="HorizontalAlignment" Value="Left" />
  </Style>

  <Style x:Key="ChatUserBubbleStyle" TargetType="Border" BasedOn="{StaticResource ChatMessageBubbleBaseStyle}">
    <Setter Property="Background" Value="{DynamicResource Brush.Theme.Message.UserBackground}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Theme.Chat.Message.UserBorder}" />
    <Setter Property="HorizontalAlignment" Value="Right" />
  </Style>

  <Style x:Key="ChatMessageTextStyle" TargetType="TextBlock">
    <Setter Property="TextWrapping" Value="Wrap" />
    <Setter Property="FontSize" Value="{StaticResource FontSize.Body}" />
    <Setter Property="LineHeight" Value="{StaticResource LineHeight.Normal}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.Chat.Message.AssistantForeground}" />
  </Style>

  <Style x:Key="ChatMessageTextUserStyle" TargetType="TextBlock" BasedOn="{StaticResource ChatMessageTextStyle}">
    <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.Chat.Message.UserForeground}" />
  </Style>

  <Style x:Key="ChatMarkdownViewerStyle" TargetType="FlowDocumentScrollViewer">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="HorizontalAlignment" Value="Left" />
    <Setter Property="IsToolBarVisible" Value="False" />
    <Setter Property="VerticalScrollBarVisibility" Value="Disabled" />
    <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
    <Setter Property="Focusable" Value="False" />
  </Style>

  <Style x:Key="ChatRoleBadgeStyle" TargetType="Border">
    <Setter Property="Background" Value="{DynamicResource Brush.Theme.Chat.RoleBadgeBackground}" />
    <Setter Property="CornerRadius" Value="{StaticResource CornerRadius.Pill}" />
    <Setter Property="Padding" Value="{StaticResource Thickness.Badge.Padding}" />
    <Setter Property="HorizontalAlignment" Value="Left" />
  </Style>

  <Style x:Key="ChatRoleBadgeTextStyle" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.Chat.RoleBadgeForeground}" />
    <Setter Property="FontSize" Value="{StaticResource FontSize.Caption}" />
    <Setter Property="FontWeight" Value="{StaticResource FontWeight.SemiBold}" />
  </Style>

  <Style x:Key="ChatTimestampTextStyle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="{StaticResource FontSize.Caption}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.Chat.Timestamp}" />
    <Setter Property="Opacity" Value="0.95" />
  </Style>

  <Style x:Key="ChatEmptyStateCardStyle" TargetType="Border" BasedOn="{StaticResource ChatCardBorderBaseStyle}">
    <Setter Property="Background" Value="{DynamicResource Brush.Theme.Chat.EmptyStateBackground}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Theme.Chat.EmptyStateBorder}" />
    <Setter Property="Padding" Value="{StaticResource Thickness.Chat.EmptyStatePadding}" />
  </Style>

  <Style x:Key="ChatComposerContainerStyle" TargetType="Border" BasedOn="{StaticResource ChatCardBorderBaseStyle}">
    <Setter Property="Background" Value="{DynamicResource Brush.Theme.Chat.ComposerBackground}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Theme.Chat.ComposerBorder}" />
    <Setter Property="Padding" Value="{StaticResource Thickness.Chat.ComposerPadding}" />
  </Style>

  <Style x:Key="ChatComposerTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource ChatBaseTextBoxStyle}">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="FontSize" Value="{StaticResource FontSize.Body}" />
  </Style>

  <Style x:Key="ChatFloatingActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ChatSecondaryButtonStyle}">
    <Setter Property="Background" Value="{DynamicResource Brush.Theme.Chat.FloatingActionBackground}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.Chat.FloatingActionForeground}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Theme.Chat.FloatingActionBorder}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Effect" Value="{StaticResource Effect.Shadow.Floating}" />
  </Style>

  <Style x:Key="ChatTypingDotStyle" TargetType="Ellipse">
    <Setter Property="Width" Value="{StaticResource Size.Chat.TypingDot}" />
    <Setter Property="Height" Value="{StaticResource Size.Chat.TypingDot}" />
    <Setter Property="Fill" Value="{DynamicResource Brush.Theme.Chat.LoadingDot}" />
    <Setter Property="Opacity" Value="0.4" />
  </Style>

</ResourceDictionary>
