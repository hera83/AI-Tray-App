<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style x:Key="ChatConversationSurfaceStyle" TargetType="Border" BasedOn="{StaticResource CardBorderBaseStyle}">
    <Setter Property="Background" Value="{DynamicResource Brush.Theme.Chat.CanvasBackground}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Theme.Border}" />
    <Setter Property="Padding" Value="{StaticResource Thickness.Chat.CanvasPadding}" />
      <Setter Property="Effect">
        <Setter.Value>
          <DropShadowEffect BlurRadius="6" ShadowDepth="0" Opacity="0.06" />
        </Setter.Value>
      </Setter>
  </Style>

  <!-- Enhanced bubble styles with interactive states -->
  <Style x:Key="ChatMessageBubbleBaseStyle" TargetType="Border">
    <Setter Property="Padding" Value="{StaticResource Thickness.Chat.BubblePadding}" />
    <Setter Property="CornerRadius" Value="{StaticResource CornerRadius.Bubble}" />
    <Setter Property="MaxWidth" Value="{StaticResource Size.ChatBubble.MaxWidth.Narrow}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Effect">
      <Setter.Value>
        <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.12" />
      </Setter.Value>
    </Setter>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Border">
          <Grid>
            <Border x:Name="BubbleBorder"
                    Background="{TemplateBinding Background}"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    Padding="{TemplateBinding Padding}"
                    Effect="{TemplateBinding Effect}" />
            <Border x:Name="HoverOverlay"
                    Background="{DynamicResource Brush.Theme.State.HoverOverlay}"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    Opacity="0" />
            <ContentPresenter />
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard TargetName="HoverOverlay" TargetProperty="Opacity" Duration="0:0:0.150">
                    <DoubleAnimation To="0.05" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard TargetName="HoverOverlay" TargetProperty="Opacity" Duration="0:0:0.150">
                    <DoubleAnimation To="0" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="ChatAssistantBubbleStyle" TargetType="Border" BasedOn="{StaticResource ChatMessageBubbleBaseStyle}">
    <Setter Property="Background" Value="{DynamicResource Brush.Theme.Message.AssistantBackground}" />
    <Setter Property="HorizontalAlignment" Value="Left" />
  </Style>

  <Style x:Key="ChatUserBubbleStyle" TargetType="Border" BasedOn="{StaticResource ChatMessageBubbleBaseStyle}">
    <Setter Property="Background" Value="{DynamicResource Brush.Theme.Message.UserBackground}" />
    <Setter Property="HorizontalAlignment" Value="Right" />
  </Style>

  <Style x:Key="ChatMessageTextStyle" TargetType="TextBlock">
    <Setter Property="TextWrapping" Value="Wrap" />
    <Setter Property="LineHeight" Value="22" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.Chat.Message.AssistantForeground}" />
  </Style>

  <Style x:Key="ChatMessageTextUserStyle" TargetType="TextBlock" BasedOn="{StaticResource ChatMessageTextStyle}">
    <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.Chat.Message.UserForeground}" />
  </Style>

  <Style x:Key="ChatRoleBadgeStyle" TargetType="Border">
    <Setter Property="Background" Value="{DynamicResource Brush.Theme.Chat.RoleBadgeBackground}" />
    <Setter Property="CornerRadius" Value="{StaticResource CornerRadius.Pill}" />
    <Setter Property="Padding" Value="{StaticResource Thickness.Badge.Padding}" />
    <Setter Property="HorizontalAlignment" Value="Left" />
  </Style>

  <Style x:Key="ChatRoleBadgeTextStyle" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.Chat.RoleBadgeForeground}" />
    <Setter Property="FontSize" Value="{StaticResource FontSize.Caption}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style x:Key="ChatTimestampTextStyle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="{StaticResource FontSize.Caption}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.Chat.Timestamp}" />
    <Setter Property="Opacity" Value="0.95" />
  </Style>

  <Style x:Key="ChatEmptyStateCardStyle" TargetType="Border" BasedOn="{StaticResource CardBorderBaseStyle}">
    <Setter Property="Background" Value="{DynamicResource Brush.Theme.Chat.EmptyStateBackground}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Theme.Chat.EmptyStateBorder}" />
    <Setter Property="Padding" Value="{StaticResource Thickness.Chat.EmptyStatePadding}" />
    <Setter Property="Template">
      <Setter Property="Effect">
        <Setter.Value>
          <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.06" />
        </Setter.Value>
      </Setter>
      <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Border">
          <Grid>
            <Border x:Name="EmptyStateBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CornerRadius.Medium}"
                    Padding="{TemplateBinding Padding}" />
            <Border x:Name="FocusHalo"
                    BorderBrush="{DynamicResource Brush.Theme.State.HoverOverlay}"
                    BorderThickness="0"
                    CornerRadius="{StaticResource CornerRadius.Medium}"
                    Opacity="0" />
            <ContentPresenter />
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard TargetName="FocusHalo" TargetProperty="Opacity" Duration="0:0:0.150">
                    <DoubleAnimation To="0.08" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard TargetName="FocusHalo" TargetProperty="Opacity" Duration="0:0:0.150">
                    <DoubleAnimation To="0" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="ChatComposerContainerStyle" TargetType="Border" BasedOn="{StaticResource CardBorderBaseStyle}">
    <Setter Property="Background" Value="{DynamicResource Brush.Theme.Chat.ComposerBackground}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Theme.Chat.ComposerBorder}" />
    <Setter Property="Padding" Value="{StaticResource Thickness.Chat.ComposerPadding}" />
      <Setter Property="Effect">
        <Setter.Value>
          <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.08" />
        </Setter.Value>
      </Setter>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Border">
          <Grid>
            <Border x:Name="ComposerBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CornerRadius.Medium}"
                    Padding="{TemplateBinding Padding}" />
            <Border x:Name="FocusRing"
                    BorderBrush="{DynamicResource Brush.Theme.State.FocusRing}"
                    BorderThickness="0"
                    CornerRadius="{StaticResource CornerRadius.Medium}"
                    Opacity="0.5" />
            <ContentPresenter />
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="ComposerBorder" Property="BorderBrush" Value="{DynamicResource Brush.Theme.State.HoverBackground}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="ChatComposerTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource BaseTextBoxStyle}">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="FontSize" Value="{StaticResource FontSize.Emphasis}" />
  </Style>

  <Style x:Key="ChatFloatingActionButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
    <Setter Property="Background" Value="{DynamicResource Brush.Theme.Chat.FloatingActionBackground}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.Chat.FloatingActionForeground}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Theme.Chat.FloatingActionBorder}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Grid>
            <Border x:Name="ActionBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="{StaticResource CornerRadius.Medium}">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True"
                                Margin="{TemplateBinding Padding}" />
            </Border>
            <Border x:Name="HoverOverlay"
                    Background="{DynamicResource Brush.Theme.State.HoverOverlay}"
                    CornerRadius="{StaticResource CornerRadius.Medium}"
                    Opacity="0" />
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard TargetName="HoverOverlay" TargetProperty="Opacity" Duration="0:0:0.100">
                    <DoubleAnimation To="0.12" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard TargetName="HoverOverlay" TargetProperty="Opacity" Duration="0:0:0.100">
                    <DoubleAnimation To="0" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="ActionBorder" Property="Background" Value="{DynamicResource Brush.Theme.State.PressedBackground}" />
              <Setter TargetName="HoverOverlay" Property="Opacity" Value="0.2" />
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="ActionBorder" Property="BorderBrush" Value="{DynamicResource Brush.Theme.State.FocusRing}" />
              <Setter TargetName="ActionBorder" Property="BorderThickness" Value="2" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="ActionBorder" Property="Opacity" Value="{StaticResource Opacity.Disabled}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="ChatTypingDotStyle" TargetType="Ellipse">
    <Setter Property="Width" Value="{StaticResource Size.Chat.TypingDot}" />
    <Setter Property="Height" Value="{StaticResource Size.Chat.TypingDot}" />
    <Setter Property="Fill" Value="{DynamicResource Brush.Theme.Chat.LoadingDot}" />
    <Setter Property="Opacity" Value="0.35" />
  </Style>

</ResourceDictionary>