<Style TargetType="ComboBox">
  <Setter Property="Template">
  <Setter.Value>
  <ControlTemplate TargetType="ComboBox">
          <Grid>
            <Border x:Name="Root"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="{StaticResource CornerRadius.Medium}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="{StaticResource Size.Control.DropdownAffordanceWidth}" />
                </Grid.ColumnDefinitions>
                <ContentPresenter Margin="{TemplateBinding Padding}"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Left"
                                  Content="{TemplateBinding SelectionBoxItem}"
                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}" />
                <Border Grid.Column="1" Background="Transparent">
                  <Path HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Data="M 0 0 L 4 4 L 8 0"
                        Stroke="{DynamicResource Brush.Theme.TextMuted}"
                        StrokeThickness="1.5" />
                </Border>
              </Grid>
            </Border>
            <Popup x:Name="PART_Popup"
                   Placement="Bottom"
                   IsOpen="{TemplateBinding IsDropDownOpen}"
                   AllowsTransparency="True"
                   PopupAnimation="Fade">
              <Border Background="{DynamicResource Brush.Theme.SurfaceElevatedBackground}"
                      BorderBrush="{DynamicResource Brush.Theme.Border}"
                      BorderThickness="1"
                      CornerRadius="{StaticResource CornerRadius.Medium}">
                <ScrollViewer Margin="{StaticResource Thickness.Popup.ContentMargin}">
                  <ItemsPresenter />
                </ScrollViewer>
              </Border>
            </Popup>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.Theme.Accent}" />
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.Theme.Accent}" />
              <Setter TargetName="Root" Property="BorderThickness" Value="2" />
            </Trigger>
            <Trigger Property="IsDropDownOpen" Value="True">
              <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.Theme.Accent}" />
              <Setter TargetName="Root" Property="BorderThickness" Value="2" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.Theme.State.DisabledBackground}" />
              <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.State.DisabledForeground}" />
              <Setter TargetName="Root" Property="Opacity" Value="{StaticResource Opacity.Disabled}" />
            </Trigger>
          </ControlTemplate.Triggers>
  </ControlTemplate>
  </Setter.Value>
  </Setter>
  </Style>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style TargetType="Window">
    <Setter Property="Background" Value="{DynamicResource Brush.Theme.WindowBackground}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.TextPrimary}" />
    <Setter Property="FontFamily" Value="{StaticResource FontFamily.Base}" />
    <Setter Property="FontSize" Value="{StaticResource FontSize.Body}" />
    <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
    <Setter Property="TextOptions.TextRenderingMode" Value="Auto" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
  </Style>

  <Style TargetType="UserControl">
    <Setter Property="Background" Value="{DynamicResource Brush.Theme.WindowBackground}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.TextPrimary}" />
    <Setter Property="FontFamily" Value="{StaticResource FontFamily.Base}" />
    <Setter Property="FontSize" Value="{StaticResource FontSize.Body}" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
  </Style>

  <Style TargetType="Grid">
    <Setter Property="SnapsToDevicePixels" Value="True" />
  </Style>

  <Style TargetType="StackPanel">
    <Setter Property="SnapsToDevicePixels" Value="True" />
  </Style>

  <Style TargetType="DockPanel">
    <Setter Property="SnapsToDevicePixels" Value="True" />
  </Style>

  <Style TargetType="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.TextPrimary}" />
      <Setter Property="SnapsToDevicePixels" Value="True" />
      <Setter Property="TextRendering" Value="ClearType" />
  </Style>

  <Style TargetType="Label">
    <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.TextSecondary}" />
    <Setter Property="FontSize" Value="{StaticResource FontSize.Body}" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
   +    <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="{StaticResource Thickness.Form.LabelBottom}" />
  </Style>

  <Style TargetType="Border">
    <Setter Property="SnapsToDevicePixels" Value="True" />
  </Style>

  <Style x:Key="BaseButtonStyle" TargetType="Button">
    <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.ButtonPrimaryForeground}" />
    <Setter Property="Background" Value="{DynamicResource Brush.Theme.ButtonPrimaryBackground}" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="{StaticResource Thickness.Button.PrimaryPadding}" />
    <Setter Property="MinHeight" Value="{StaticResource Size.Button.MinHeight}" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Grid>
            <Border x:Name="Root"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="{StaticResource CornerRadius.Medium}">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True"
                                Margin="{TemplateBinding Padding}" />
            </Border>
            <Border x:Name="HoverOverlay"
                    Background="{DynamicResource Brush.Theme.State.HoverOverlay}"
                    CornerRadius="{StaticResource CornerRadius.Medium}"
                    Opacity="0" />
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard TargetName="HoverOverlay" TargetProperty="Opacity" Duration="0:0:0.100">
                    <DoubleAnimation To="0.12" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard TargetName="HoverOverlay" TargetProperty="Opacity" Duration="0:0:0.100">
                    <DoubleAnimation To="0" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.Theme.State.PressedBackground}" />
              <Setter TargetName="HoverOverlay" Property="Opacity" Value="0.2" />
            </Trigger>
              <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.Theme.Accent}" />
                <Setter TargetName="Root" Property="BorderThickness" Value="2" />
            </Trigger>
              <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.Theme.Accent}" />
                <Setter TargetName="Root" Property="BorderThickness" Value="2" />
              </Trigger>
            <MultiTrigger>
              <MultiTrigger.Conditions>
                <Condition Property="IsMouseOver" Value="True" />
                <Condition Property="IsKeyboardFocused" Value="True" />
              </MultiTrigger.Conditions>
              <Setter TargetName="Root" Property="BorderThickness" Value="{StaticResource Thickness.Border.Focused}" />
              <Trigger Property="IsMouseOver" Value="True">
                <Trigger.EnterActions>
                  <BeginStoryboard>
                    <Storyboard TargetName="HoverOverlay" TargetProperty="Opacity" Duration="0:0:0.100">
                      <DoubleAnimation To="0.1" />
                    </Storyboard>
                  </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                  <BeginStoryboard>
                    <Storyboard TargetName="HoverOverlay" TargetProperty="Opacity" Duration="0:0:0.100">
                      <DoubleAnimation To="0" />
                    </Storyboard>
                  </BeginStoryboard>
                </Trigger.ExitActions>
                <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Brush.Theme.Accent}" />
              </Trigger>
            </MultiTrigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Brush.Theme.Accent}" />
                <Setter TargetName="Box" Property="BorderThickness" Value="2" />
              <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.State.DisabledForeground}" />
              <Setter TargetName="Root" Property="Opacity" Value="{StaticResource Opacity.Disabled}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}" />

  <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
    <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.ButtonSecondaryForeground}" />
    <Setter Property="Background" Value="{DynamicResource Brush.Theme.ButtonSecondaryBackground}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Theme.Border}" />
    <Setter Property="Padding" Value="{StaticResource Thickness.Button.SecondaryPadding}" />
  </Style>

  <Style x:Key="BaseToggleButtonStyle" TargetType="ToggleButton" BasedOn="{StaticResource BaseButtonStyle}">
    <Style.Triggers>
      <Trigger Property="IsChecked" Value="True">
        <Setter Property="Background" Value="{DynamicResource Brush.Theme.Accent}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.TextOnAccent}" />
      </Trigger>
    </Style.Triggers>>
  </Style>

  <Style TargetType="ToggleButton" BasedOn="{StaticResource BaseToggleButtonStyle}" />

  <Style x:Key="BaseTextBoxStyle" TargetType="TextBox">
    <Setter Property="Background" Value="{DynamicResource Brush.Theme.InputBackground}"/>
    <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.InputForeground}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Theme.Border}"/>
    <Setter Property="BorderThickness" Value="{StaticResource Thickness.Border.Normal}"/>
    <Setter Property="Padding" Value="{StaticResource Thickness.Input.ControlPadding}"/>
    <Setter Property="FontSize" Value="{StaticResource FontSize.Body}"/>
    <Setter Property="CaretBrush" Value="{DynamicResource Brush.Theme.InputForeground}"/>
    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TextBox">
          <Border x:Name="Root"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="{StaticResource CornerRadius.Medium}">
            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.Theme.Accent}" />
              <Setter TargetName="Root" Property="BorderThickness" Value="1" />
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.Theme.Accent}" />
              <Setter TargetName="Root" Property="BorderThickness" Value="2" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.Theme.State.DisabledBackground}" />
              <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.State.DisabledForeground}" />
              <Setter TargetName="Root" Property="Opacity" Value="{StaticResource Opacity.Disabled}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="TextBox" BasedOn="{StaticResource BaseTextBoxStyle}" />

  <Style x:Key="BasePasswordBoxStyle" TargetType="PasswordBox">
    <Setter Property="Background" Value="{DynamicResource Brush.Theme.InputBackground}"/>
    <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.InputForeground}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Theme.Border}"/>
    <Setter Property="BorderThickness" Value="{StaticResource Thickness.Border.Normal}"/>
    <Setter Property="Padding" Value="{StaticResource Thickness.Input.ControlPadding}"/>
    <Setter Property="FontSize" Value="{StaticResource FontSize.Body}"/>
    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="PasswordBox">
          <Border x:Name="Root"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="{StaticResource CornerRadius.Medium}">
            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.Theme.Accent}" />
              <Setter TargetName="Root" Property="BorderThickness" Value="1" />
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.Theme.Accent}" />
              <Setter TargetName="Root" Property="BorderThickness" Value="2" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.Theme.State.DisabledBackground}" />
              <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.State.DisabledForeground}" />
              <Setter TargetName="Root" Property="Opacity" Value="{StaticResource Opacity.Disabled}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="PasswordBox" BasedOn="{StaticResource BasePasswordBoxStyle}" />

  <Style TargetType="ComboBox">
    <Setter Property="Background" Value="{DynamicResource Brush.Theme.InputBackground}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.InputForeground}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Theme.Border}" />
    <Setter Property="BorderThickness" Value="{StaticResource Thickness.Border.Normal}" />
    <Setter Property="Padding" Value="{StaticResource Thickness.Input.ControlPadding}" />
    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ComboBox">
          <Grid>
            <Border x:Name="Root"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="{StaticResource CornerRadius.Medium}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="{StaticResource Size.Control.DropdownAffordanceWidth}" />
                </Grid.ColumnDefinitions>
                <ContentPresenter Margin="{TemplateBinding Padding}"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Left"
                                  Content="{TemplateBinding SelectionBoxItem}"
                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}" />
                <Border Grid.Column="1" Background="Transparent">
                  <Path HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Data="M 0 0 L 4 4 L 8 0"
                        Stroke="{DynamicResource Brush.Theme.TextMuted}"
                        StrokeThickness="1.5" />
                </Border>
              </Grid>
            </Border>
            <Popup x:Name="PART_Popup"
                   Placement="Bottom"
                   IsOpen="{TemplateBinding IsDropDownOpen}"
                   AllowsTransparency="True"
                   PopupAnimation="Fade">
              <Border Background="{DynamicResource Brush.Theme.SurfaceElevatedBackground}"
                      BorderBrush="{DynamicResource Brush.Theme.Border}"
                      BorderThickness="1"
                      CornerRadius="{StaticResource CornerRadius.Medium}">
                <ScrollViewer Margin="{StaticResource Thickness.Popup.ContentMargin}">
                  <ItemsPresenter />
                </ScrollViewer>
              </Border>
            </Popup>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.Theme.State.HoverBackground}" />
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.Theme.State.FocusRing}" />
              <Setter TargetName="Root" Property="BorderThickness" Value="{StaticResource Thickness.Border.Focused}" />
            </Trigger>
            <Trigger Property="IsDropDownOpen" Value="True">
              <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.Theme.State.FocusRing}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.Theme.State.DisabledBackground}" />
              <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.State.DisabledForeground}" />
              <Setter TargetName="Root" Property="Opacity" Value="{StaticResource Opacity.Disabled}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="ComboBoxItem">
    <Setter Property="Padding" Value="{StaticResource Thickness.List.ItemPadding}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.TextPrimary}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ComboBoxItem">
          <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="{StaticResource CornerRadius.Small}">
            <ContentPresenter Margin="{TemplateBinding Padding}" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard TargetName="Root" TargetProperty="Background" Duration="0:0:0.100">
                    <ColorAnimation To="{DynamicResource Color.Theme.State.HoverBackground}" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard TargetName="Root" TargetProperty="Background" Duration="0:0:0.100">
                    <ColorAnimation To="Transparent" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.Theme.Accent}" />
              <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.TextOnAccent}" />
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.Theme.Accent}" />
                <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.TextOnAccent}" />
                <Setter TargetName="Root" Property="Opacity" Value="1" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="ListBox">
    <Setter Property="Background" Value="{DynamicResource Brush.Theme.SurfaceBackground}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Theme.Border}" />
    <Setter Property="BorderThickness" Value="{StaticResource Thickness.Border.Normal}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.TextPrimary}" />
    <Setter Property="Padding" Value="4" />
  </Style>

  <Style TargetType="ListBoxItem">
    <Setter Property="Padding" Value="{StaticResource Thickness.List.ItemPadding}" />
    <Setter Property="Margin" Value="{StaticResource Thickness.List.ItemMargin}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ListBoxItem">
          <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="{StaticResource CornerRadius.Small}">
            <ContentPresenter Margin="{TemplateBinding Padding}" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard TargetName="Root" TargetProperty="Background" Duration="0:0:0.100">
                    <ColorAnimation To="{DynamicResource Color.Theme.State.HoverBackground}" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard TargetName="Root" TargetProperty="Background" Duration="0:0:0.100">
                    <ColorAnimation To="Transparent" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.Theme.Accent}" />
              <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.TextOnAccent}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="ListView" BasedOn="{StaticResource {x:Type ListBox}}" />

  <Style TargetType="ListViewItem" BasedOn="{StaticResource {x:Type ListBoxItem}}" />

  <Style TargetType="ScrollViewer">
    <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.TextPrimary}" />
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style TargetType="Thumb">
    <Setter Property="OverridesDefaultStyle" Value="True" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Thumb">
          <Border x:Name="ThumbBorder"
                  Background="{DynamicResource Brush.Theme.Divider}"
                  CornerRadius="{StaticResource CornerRadius.Pill}"
                  Opacity="0.6" />
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard TargetName="ThumbBorder" TargetProperty="Opacity" Duration="0:0:0.100">
                    <DoubleAnimation To="1" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard TargetName="ThumbBorder" TargetProperty="Opacity" Duration="0:0:0.150">
                    <DoubleAnimation To="0.6" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="ScrollBar">
    <Setter Property="Width" Value="{StaticResource Size.Control.ScrollBarThickness}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ScrollBar">
          <Grid Background="{TemplateBinding Background}">
            <Track x:Name="PART_Track" IsDirectionReversed="True">
              <Track.Thumb>
                <Thumb />
              </Track.Thumb>
            </Track>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
              <Setter Property="Height" Value="{StaticResource Size.Control.ScrollBarThickness}" />
              <Setter Property="Width" Value="Auto" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="CheckBox">
    <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.TextSecondary}"/>
    <Setter Property="FontSize" Value="{StaticResource FontSize.Body}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="CheckBox">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="{StaticResource Size.CheckBox.Column}" />
              <ColumnDefinition Width="{StaticResource Size.CheckBox.Gap}" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border x:Name="Box"
                    Width="{StaticResource Size.CheckBox.Box}"
                    Height="{StaticResource Size.CheckBox.Box}"
                    CornerRadius="{StaticResource CornerRadius.Small}"
                    Background="{DynamicResource Brush.Theme.InputBackground}"
                    BorderBrush="{DynamicResource Brush.Theme.Border}"
                    BorderThickness="{StaticResource Thickness.Border.Normal}" />
            <Border x:Name="HoverOverlay"
                    Width="{StaticResource Size.CheckBox.Box}"
                    Height="{StaticResource Size.CheckBox.Box}"
                    CornerRadius="{StaticResource CornerRadius.Small}"
                    Background="{DynamicResource Brush.Theme.State.HoverOverlay}"
                    Opacity="0" />
            <Path x:Name="Glyph"
                  Grid.Column="0"
                  Data="M 3 8 L 7 12 L 13 4"
                  Stroke="{DynamicResource Brush.Theme.TextOnAccent}"
                  StrokeThickness="2"
                  Visibility="Collapsed" />
            <ContentPresenter Grid.Column="2" VerticalAlignment="Center" RecognizesAccessKey="True" />
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard TargetName="HoverOverlay" TargetProperty="Opacity" Duration="0:0:0.100">
                    <DoubleAnimation To="0.15" />
                      <DoubleAnimation To="0.1" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard TargetName="HoverOverlay" TargetProperty="Opacity" Duration="0:0:0.100">
                    <DoubleAnimation To="0" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
                <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Brush.Theme.Accent}" />
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="Box" Property="Background" Value="{DynamicResource Brush.Theme.Accent}" />
              <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Brush.Theme.Accent}" />
              <Setter TargetName="Glyph" Property="Visibility" Value="Visible" />
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Brush.Theme.State.FocusRing}" />
              <Setter TargetName="Box" Property="BorderThickness" Value="{StaticResource Thickness.Border.Focused}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Box" Property="Background" Value="{DynamicResource Brush.Theme.State.DisabledBackground}" />
              <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Brush.Theme.Divider}" />
              <Setter TargetName="Box" Property="Opacity" Value="{StaticResource Opacity.Disabled}" />
              <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.State.DisabledForeground}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="Menu">
    <Setter Property="Background" Value="{DynamicResource Brush.Theme.SurfaceBackground}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.TextPrimary}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Theme.Border}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style TargetType="MenuItem">
    <Setter Property="Padding" Value="{StaticResource Thickness.Menu.ItemPadding}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.TextPrimary}" />
    <Setter Property="Background" Value="Transparent" />
    <Style.Triggers>
      <Trigger Property="IsHighlighted" Value="True">
        <Setter Property="Background" Value="{DynamicResource Brush.Theme.State.HoverBackground}" />
      </Trigger>
      <Trigger Property="IsEnabled" Value="False">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.State.DisabledForeground}" />
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style TargetType="ContextMenu">
    <Setter Property="Background" Value="{DynamicResource Brush.Theme.SurfaceElevatedBackground}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Theme.Border}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="4" />
  </Style>

  <Style TargetType="ToolTip">
    <Setter Property="Background" Value="{DynamicResource Brush.Theme.SurfaceElevatedBackground}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.TextPrimary}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Theme.Border}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="{StaticResource Thickness.ToolTip.Padding}" />
  </Style>

  <Style TargetType="Separator">
    <Setter Property="Background" Value="{DynamicResource Brush.Theme.Divider}" />
      <Setter Property="Margin" Value="0,8,0,8" />
  </Style>

  <Style x:Key="CardBorderBaseStyle" TargetType="Border">
    <Setter Property="CornerRadius" Value="{StaticResource CornerRadius.Large}" />
    <Setter Property="Padding" Value="{StaticResource Thickness.Card.Padding}" />
    <Setter Property="Background" Value="{DynamicResource Brush.Theme.SurfaceElevatedBackground}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Theme.Border}" />
    <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Effect">
        <Setter.Value>
          <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.08" />
        </Setter.Value>
      </Setter>
  </Style>

  <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
    <Setter Property="Padding" Value="{StaticResource Thickness.Button.PrimaryPadding}" />
    <Setter Property="MinWidth" Value="80" />
    <Setter Property="Background" Value="{DynamicResource Brush.Theme.ButtonPrimaryBackground}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.ButtonPrimaryForeground}" />
  </Style>

  <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
    <Setter Property="Padding" Value="{StaticResource Thickness.Button.SecondaryPadding}" />
    <Setter Property="MinWidth" Value="70" />
    <Setter Property="Background" Value="{DynamicResource Brush.Theme.ButtonSecondaryBackground}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.ButtonSecondaryForeground}" />
    <Setter Property="FontWeight" Value="Normal" />
  </Style>

  <Style x:Key="InputTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource BaseTextBoxStyle}" />

  <Style x:Key="InputPasswordBoxStyle" TargetType="PasswordBox" BasedOn="{StaticResource BasePasswordBoxStyle}" />

  <Style x:Key="ModernCheckBoxStyle" TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
    <Setter Property="Margin" Value="0,6,0,0"/>
  </Style>

  <Style x:Key="PanelSeparatorStyle" TargetType="Separator" BasedOn="{StaticResource {x:Type Separator}}" />

  <Style x:Key="StatusCardStyle" TargetType="Border" BasedOn="{StaticResource CardBorderBaseStyle}">
    <Setter Property="Margin" Value="0,8,0,10"/>
  </Style>

  <Style x:Key="ErrorBannerStyle" TargetType="Border" BasedOn="{StaticResource CardBorderBaseStyle}">
    <Setter Property="Margin" Value="0,6,0,12"/>
    <Setter Property="Background" Value="{DynamicResource Brush.Theme.Feedback.ErrorBackground}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Theme.Feedback.ErrorBorder}"/>
  </Style>

  <!-- Validation error states for input controls -->
  <Style x:Key="TextBoxErrorStyle" TargetType="TextBox" BasedOn="{StaticResource BaseTextBoxStyle}">
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Theme.Feedback.Error}" />
    <Setter Property="BorderThickness" Value="{StaticResource Thickness.Border.Normal}" />
    <Style.Triggers>
      <Trigger Property="IsKeyboardFocused" Value="True">
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Theme.Feedback.Error}" />
        <Setter Property="BorderThickness" Value="{StaticResource Thickness.Border.Focused}" />
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style x:Key="PasswordBoxErrorStyle" TargetType="PasswordBox" BasedOn="{StaticResource BasePasswordBoxStyle}">
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Theme.Feedback.Error}" />
    <Setter Property="BorderThickness" Value="{StaticResource Thickness.Border.Normal}" />
  </Style>

  <Style x:Key="ComboBoxErrorStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Theme.Feedback.Error}" />
    <Setter Property="BorderThickness" Value="{StaticResource Thickness.Border.Normal}" />
  </Style>

  <!-- Error message text style -->
  <Style x:Key="ValidationErrorTextStyle" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.Feedback.Error}" />
    <Setter Property="FontSize" Value="{StaticResource FontSize.Caption}" />
    <Setter Property="Margin" Value="0,4,0,0" />
  </Style>

  <!-- Error state container with subtle background -->
  <Style x:Key="ValidationErrorContainerStyle" TargetType="Border">
    <Setter Property="Background" Value="{DynamicResource Brush.Theme.Feedback.ErrorBackground}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Theme.Feedback.ErrorBorder}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource CornerRadius.Small}" />
    <Setter Property="Padding" Value="8,6,8,6" />
    <Setter Property="Margin" Value="0,4,0,0" />
  </Style>

  <!-- Success state container -->
  <Style x:Key="ValidationSuccessContainerStyle" TargetType="Border">
    <Setter Property="Background" Value="{DynamicResource Brush.Theme.Feedback.SuccessBackground}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Theme.Feedback.SuccessBorder}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource CornerRadius.Small}" />
    <Setter Property="Padding" Value="8,6,8,6" />
    <Setter Property="Margin" Value="0,4,0,0" />
  </Style>

  <!-- Warning state container -->
  <Style x:Key="ValidationWarningContainerStyle" TargetType="Border">
    <Setter Property="Background" Value="{DynamicResource Brush.Theme.Feedback.WarningBackground}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Theme.Feedback.WarningBorder}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource CornerRadius.Small}" />
    <Setter Property="Padding" Value="8,6,8,6" />
    <Setter Property="Margin" Value="0,4,0,0" />
  </Style>

  <!-- Info state container -->
  <Style x:Key="ValidationInfoContainerStyle" TargetType="Border">
    <Setter Property="Background" Value="{DynamicResource Brush.Theme.Feedback.InfoBackground}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Theme.Feedback.InfoBorder}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource CornerRadius.Small}" />
    <Setter Property="Padding" Value="8,6,8,6" />
    <Setter Property="Margin" Value="0,4,0,0" />
  </Style>

  <!-- Feedback text styles -->
  <Style x:Key="ValidationSuccessTextStyle" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.Feedback.SuccessForeground}" />
    <Setter Property="FontSize" Value="{StaticResource FontSize.Caption}" />
  </Style>

  <Style x:Key="ValidationWarningTextStyle" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.Feedback.WarningForeground}" />
    <Setter Property="FontSize" Value="{StaticResource FontSize.Caption}" />
  </Style>

  <Style x:Key="ValidationInfoTextStyle" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.Feedback.InfoForeground}" />
    <Setter Property="FontSize" Value="{StaticResource FontSize.Caption}" />
  </Style>

  <!-- Chat message bubble hover states -->
  <Style x:Key="ChatMessageContainerStyle" TargetType="Border">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Border">
          <Grid>
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    Padding="{TemplateBinding Padding}" />
            <Border x:Name="HoverHalo"
                    Background="{DynamicResource Brush.Theme.State.HoverOverlay}"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    Opacity="0" />
            <ContentPresenter />
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard TargetName="HoverHalo" TargetProperty="Opacity" Duration="0:0:0.150">
                    <DoubleAnimation To="0.08" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard TargetName="HoverHalo" TargetProperty="Opacity" Duration="0:0:0.150">
                    <DoubleAnimation To="0" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

</ResourceDictionary>