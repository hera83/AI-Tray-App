<Window x:Class="TrayApp.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:TrayApp.Behaviors"
    xmlns:converters="clr-namespace:TrayApp.Converters"
        Title="AI Assistent"
        Height="{StaticResource Size.Window.Main.Height}"
        Width="{StaticResource Size.Window.Main.Width}"
        ResizeMode="NoResize"
        Background="{DynamicResource Brush.Theme.WindowBackground}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVisibilityConverter" />
        <converters:MarkdownMessageToFlowDocumentConverter x:Key="MarkdownMessageToFlowDocumentConverter" />

        <DataTemplate x:Key="ChatMessageTemplate">
            <Grid x:Name="MessageRow" Margin="{StaticResource Thickness.Chat.Row.Left}">
                <StackPanel>
                    <Border x:Name="MessageBubble" Style="{StaticResource ChatAssistantBubbleStyle}" Margin="{StaticResource Thickness.Chat.Bubble.Left}">
                        <StackPanel>
                            <FlowDocumentScrollViewer x:Name="MessageMarkdown"
                                                      Document="{Binding Content, Converter={StaticResource MarkdownMessageToFlowDocumentConverter}}"
                                                      Style="{StaticResource ChatMarkdownViewerStyle}"
                                                      Visibility="{Binding Content, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                            </FlowDocumentScrollViewer>

                            <StackPanel x:Name="TypingIndicator" Orientation="Horizontal" Visibility="Collapsed">
                                <Ellipse Style="{StaticResource ChatTypingDotStyle}">
                                    <Ellipse.Triggers>
                                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.25" To="1" Duration="0:0:0.55" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                                <Ellipse Style="{StaticResource ChatTypingDotStyle}" Margin="{StaticResource Thickness.Chat.TypingDotGap}">
                                    <Ellipse.Triggers>
                                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True" BeginTime="0:0:0.15">
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.25" To="1" Duration="0:0:0.55" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                                <Ellipse Style="{StaticResource ChatTypingDotStyle}" Margin="{StaticResource Thickness.Chat.TypingDotGap}">
                                    <Ellipse.Triggers>
                                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True" BeginTime="0:0:0.3">
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.25" To="1" Duration="0:0:0.55" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                                <TextBlock Text="AI skriver..." Style="{StaticResource CaptionStyle}" Margin="{StaticResource Thickness.Inline.Left.10}" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock x:Name="MessageTimestamp"
                               Text="{Binding CreatedAt, StringFormat='{}{0:dd.MM.yyyy · HH:mm}'}"
                               Style="{StaticResource ChatTimestampTextStyle}"
                               Margin="{StaticResource Thickness.Chat.Timestamp}"
                               HorizontalAlignment="Left" />
                </StackPanel>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Role}" Value="User">
                    <Setter TargetName="MessageRow" Property="Margin" Value="{StaticResource Thickness.Chat.Row.Right}" />
                    <Setter TargetName="MessageBubble" Property="Style" Value="{StaticResource ChatUserBubbleStyle}" />
                    <Setter TargetName="MessageTimestamp" Property="HorizontalAlignment" Value="Right" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsStreaming}" Value="True">
                    <Setter TargetName="TypingIndicator" Property="Visibility" Value="Visible" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Width="{StaticResource Size.Sidebar.Width}"
                Background="{DynamicResource Brush.Theme.SidebarBackground}"
                Padding="{StaticResource Thickness.Sidebar.Padding}"
                Visibility="{Binding IsHistoryPaneExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="Chat-historik" Style="{StaticResource Heading3Style}" Margin="{StaticResource Thickness.Margin.Bottom.8}" />

                <ListBox Grid.Row="1"
                         ItemsSource="{Binding ChatSessions}"
                         SelectedItem="{Binding ActiveSession, Mode=TwoWay}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.TextPrimary}" />
                            <Setter Property="Padding" Value="{StaticResource Thickness.List.ItemPadding}" />
                            <Setter Property="Margin" Value="{StaticResource Thickness.List.ItemMargin}" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="ItemBorder"
                                                Padding="{TemplateBinding Padding}"
                                                CornerRadius="{StaticResource CornerRadius.Medium}"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                BorderThickness="1">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource Brush.Theme.SurfaceBackground}" />
                                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource Brush.Theme.Border}" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource Brush.Theme.Accent}" />
                                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource Brush.Theme.Accent}" />
                                                <Setter Property="Foreground" Value="{DynamicResource Brush.Theme.TextOnAccent}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Title}" FontSize="{StaticResource FontSize.Body}" FontWeight="{StaticResource FontWeight.Medium}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding UpdatedAt, StringFormat='{}{0:dd.MM.yyyy \u00b7 HH:mm}'}" FontSize="{StaticResource FontSize.Caption}" Margin="{StaticResource Thickness.Margin.Top.2}" Opacity="0.9" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="Slet"
                                        Command="{Binding DataContext.DeleteSessionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        VerticalAlignment="Center"
                                        Margin="{StaticResource Thickness.Margin.Left.6}"
                                        ToolTip="Slet samtale"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="{StaticResource Thickness.Page.MainPadding}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" LastChildFill="False" Margin="{StaticResource Thickness.Form.FieldBottom}">
                <Button DockPanel.Dock="Left"
                        Content="{Binding HistoryPaneToggleText}"
                        Command="{Binding ToggleHistoryPaneCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" />
                <Button DockPanel.Dock="Right"
                        Content="Ny chat"
                        Command="{Binding NewChatCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" />
            </DockPanel>

            <!-- Messages -->
            <Grid Grid.Row="1">
                <Border Style="{StaticResource ChatConversationSurfaceStyle}">
                    <ScrollViewer x:Name="MessagesScroll" Grid.Row="0" VerticalScrollBarVisibility="Auto" Background="Transparent"
                                  behaviors:ScrollViewerBehavior.Monitor="True"
                                  behaviors:ScrollViewerBehavior.IsNearBottom="{Binding IsUserNearBottom, Mode=TwoWay}"
                                  behaviors:ScrollViewerBehavior.ScrollToBottomTrigger="{Binding ScrollToBottomRequest}">
                        <ItemsControl ItemsSource="{Binding Messages}"
                                      ItemTemplate="{StaticResource ChatMessageTemplate}" />
                </ScrollViewer>
                    </Border>

                <!-- empty state when no messages -->
                <Border Background="Transparent"
                        IsHitTestVisible="False"
                        Visibility="{Binding ShowConfigurationEmptyState, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Border Width="{StaticResource Size.Chat.EmptyStateHalo}" Height="{StaticResource Size.Chat.EmptyStateHalo}" Background="{DynamicResource Brush.Theme.Chat.EmptyStateAccent}" CornerRadius="{StaticResource CornerRadius.Circle.Halo}" Opacity="0.8" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <Border Style="{StaticResource ChatEmptyStateCardStyle}" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <StackPanel>
                                <Border Width="{StaticResource Size.Chat.EmptyStateBadge}" Height="{StaticResource Size.Chat.EmptyStateBadge}" Background="{DynamicResource Brush.Theme.Chat.RoleBadgeBackground}" CornerRadius="{StaticResource CornerRadius.Circle.Badge}" HorizontalAlignment="Center">
                                    <TextBlock Text="AI" HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource BodyLargeStyle}" />
                                </Border>
                                <TextBlock Text="{Binding EmptyStateTitle}" Style="{StaticResource Heading1Style}" HorizontalAlignment="Center" Margin="{StaticResource Thickness.Form.SectionGap}" />
                                <TextBlock Text="{Binding EmptyStateDescription}" Style="{StaticResource BodyStyle}" HorizontalAlignment="Center" Margin="{StaticResource Thickness.Form.FieldBottom}" TextWrapping="Wrap" TextAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Go to latest button -->
                <Button Content="Gå til nyeste" Width="{StaticResource Size.Chat.FloatingButton.Width}" Height="{StaticResource Size.Chat.FloatingButton.Height}" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="{StaticResource Thickness.Chat.FloatingButton}"
                        Visibility="{Binding ShowNewMessages, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Command="{Binding GoToLatestCommand}"
                        Style="{StaticResource ChatFloatingActionButtonStyle}" />
            </Grid>

            <!-- Input area -->
            <Border Grid.Row="2" Style="{StaticResource ChatComposerContainerStyle}" Margin="{StaticResource Thickness.Chat.ComposerTop}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Margin="{StaticResource Thickness.Margin.Bottom.6}">
                            <Ellipse Style="{StaticResource ChatTypingDotStyle}">
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.25" To="1" Duration="0:0:0.55" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                            <Ellipse Style="{StaticResource ChatTypingDotStyle}" Margin="{StaticResource Thickness.Chat.TypingDotGap}">
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True" BeginTime="0:0:0.15">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.25" To="1" Duration="0:0:0.55" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                            <Ellipse Style="{StaticResource ChatTypingDotStyle}" Margin="{StaticResource Thickness.Chat.TypingDotGap}">
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True" BeginTime="0:0:0.3">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.25" To="1" Duration="0:0:0.55" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                        <TextBlock Text="AI arbejder på svaret..." Style="{StaticResource CaptionStyle}" Margin="{StaticResource Thickness.Inline.Left.10}" VerticalAlignment="Center" />
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 x:Name="InputBox"
                                 Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 MinHeight="{StaticResource Size.Input.MinHeight}"
                                 Style="{StaticResource ChatComposerTextBoxStyle}"
                                 Margin="{StaticResource Thickness.Margin.Right.8}"
                                 IsEnabled="{Binding IsInputEnabled}"
                                 ToolTip="Shift+Enter for ny linje · Enter for at sende"
                                 behaviors:EnterKeyBehavior.SendCommand="{Binding SendCommand}"
                                 behaviors:TextBoxAutoGrowBehavior.EnableAutoGrow="True"
                                 behaviors:TextBoxAutoGrowBehavior.MinHeight="{StaticResource Size.Input.MinHeight}"
                                 behaviors:TextBoxAutoGrowBehavior.MaxHeight="{StaticResource Size.Input.MaxHeight}" />

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                            <Button Content="Stop"
                                    Command="{Binding StopGenerationCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="{StaticResource Thickness.Margin.Right.8}"
                                    Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <Button Content="Send"
                                    Command="{Binding SendCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    IsEnabled="{Binding CanSend}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
